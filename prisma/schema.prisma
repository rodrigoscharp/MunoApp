generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String             @id @default(cuid())
  nome      String
  slug      String             @unique
  plano     String             @default("free")
  status    String             @default("active")
  createdAt DateTime           @default(now())

  users             User[]
  categories        Category[]
  menuItems         MenuItem[]
  orders            Order[]
  tables            Table[]
  payments          Payment[]
  settings          Setting[]
  deliveryZones     DeliveryZone[]
  chatMessages      ChatMessage[]
  paymentConnections PaymentConnection[]
  passwordResetTokens PasswordResetToken[]
}

model PaymentConnection {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  provider     String   @default("mercado_pago")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  status       String   @default("active") // 'active' | 'needs_reauth'
  mpUserId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model User {
  id                String             @id @default(cuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  name              String
  email             String
  password          String?
  role              Role               @default(CUSTOMER)
  orders            Order[]
  motoboyOrders     Order[]            @relation("MotoboyOrders")
  deliveryTrackings DeliveryTracking[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum Role {
  CUSTOMER
  ADMIN
  KITCHEN
  MOTOBOY
}

model Category {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  slug      String
  position  Int        @default(0)
  items     MenuItem[]
  createdAt DateTime   @default(now())

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model MenuItem {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  available   Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId])
}

model Order {
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  status              OrderStatus       @default(PENDING)
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus     @default(UNPAID)
  mpPaymentId         String?
  total               Decimal           @db.Decimal(10, 2)
  notes               String?
  customerName        String?
  customerPhone       String?
  deliveryType        DeliveryType      @default(PICKUP)
  deliveryAddress     String?
  deliveryFee         Decimal           @default(0) @db.Decimal(10, 2)
  estimatedDeliveryAt DateTime?
  userId              String?
  user                User?             @relation(fields: [userId], references: [id])
  motoboyId           String?
  motoboy             User?             @relation("MotoboyOrders", fields: [motoboyId], references: [id])
  tableId             String?
  table               Table?            @relation(fields: [tableId], references: [id])
  deliveryTracking    DeliveryTracking?
  items               OrderItem[]
  chatMessages        ChatMessage[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([tenantId])
}

model Table {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  number    Int
  name      String?
  token     String    @default(cuid())
  active    Boolean   @default(true)
  orders    Order[]
  payments  Payment[]
  createdAt DateTime  @default(now())

  @@unique([tenantId, number])
  @@unique([tenantId, token])
  @@index([tenantId])
}

model Payment {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  tableId   String?
  table     Table?        @relation(fields: [tableId], references: [id])
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())

  @@index([tenantId])
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  email     String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model DeliveryTracking {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  motoboyId String
  motoboy   User     @relation(fields: [motoboyId], references: [id])
  lat       Float
  lng       Float
  startedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DeliveryType {
  PICKUP
  DELIVERY
  DINE_IN
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  notes      String?
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PREPARATION
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  CASH
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model DeliveryZone {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  price     Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderRole String   // "CUSTOMER" | "ADMIN"
  senderId   String?
  senderName String?
  content    String
  createdAt  DateTime @default(now())

  @@index([orderId])
  @@index([tenantId])
}
