generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String?
  role              Role               @default(CUSTOMER)
  orders            Order[]
  motoboyOrders     Order[]            @relation("MotoboyOrders")
  deliveryTrackings DeliveryTracking[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
  KITCHEN
  MOTOBOY
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  position  Int        @default(0)
  items     MenuItem[]
  createdAt DateTime   @default(now())
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  available   Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id                  String            @id @default(cuid())
  status              OrderStatus       @default(PENDING)
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus     @default(UNPAID)
  mpPaymentId         String?
  total               Decimal           @db.Decimal(10, 2)
  notes               String?
  customerName        String?
  customerPhone       String?
  deliveryType        DeliveryType      @default(PICKUP)
  deliveryAddress     String?
  deliveryFee         Decimal           @default(0) @db.Decimal(10, 2)
  estimatedDeliveryAt DateTime?
  userId              String?
  user                User?             @relation(fields: [userId], references: [id])
  motoboyId           String?
  motoboy             User?             @relation("MotoboyOrders", fields: [motoboyId], references: [id])
  tableId             String?
  table               Table?            @relation(fields: [tableId], references: [id])
  deliveryTracking    DeliveryTracking?
  items               OrderItem[]
  chatMessages        ChatMessage[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Table {
  id        String    @id @default(cuid())
  number    Int       @unique
  name      String?
  token     String    @unique @default(cuid())
  active    Boolean   @default(true)
  orders    Order[]
  payments  Payment[]
  createdAt DateTime  @default(now())
}

model Payment {
  id        String        @id @default(cuid())
  tableId   String?
  table     Table?        @relation(fields: [tableId], references: [id])
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model DeliveryTracking {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  motoboyId String
  motoboy   User     @relation(fields: [motoboyId], references: [id])
  lat       Float
  lng       Float
  startedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DeliveryType {
  PICKUP
  DELIVERY
  DINE_IN
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  notes      String?
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PREPARATION
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  CASH
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model DeliveryZone {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderRole String   // "CUSTOMER" | "ADMIN"
  senderId   String?
  senderName String?
  content    String
  createdAt  DateTime @default(now())

  @@index([orderId])
}
